@model Cinema
@{
    ViewData["Title"] = Model.Name;
}

<h1>@Model.Name</h1>
<p class="text-muted">@Model.Address, @Model.City</p>

@foreach (var hall in Model.Halls)
{
    <h3>@hall.Name <span class="text-muted">(@hall.Capacity seats)</span></h3>

    @if (!hall.Showtimes.Any())
    {
        <p class="text-muted">No upcoming showtimes in this hall.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Movie</th>
                    <th>Date &amp; Time</th>
                    <th>Price</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var showtime in hall.Showtimes.OrderBy(s => s.StartTime))
                {
                    <tr>
                        <td data-label="Movie">@showtime.Movie?.Title</td>
                        <td data-label="Date & Time">@showtime.StartTime.ToString("ddd, dd MMM yyyy - HH:mm")</td>
                        <td data-label="Price">@showtime.TicketPrice.ToString("C")</td>
                        <td data-label="">
                            <a class="btn btn-secondary btn-sm" asp-controller="Movies" asp-action="Details" asp-route-id="@showtime.MovieId">View Movie</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
