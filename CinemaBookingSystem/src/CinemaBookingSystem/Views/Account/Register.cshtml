@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<h1>Create an Account</h1>

<form asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="form form-narrow">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="form-group">
        <label asp-for="FullName"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Password"></label>
        <input asp-for="Password" class="form-control" />
        <span asp-validation-for="Password" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="ConfirmPassword"></label>
        <input asp-for="ConfirmPassword" class="form-control" />
        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
    </div>

    <button type="submit" class="btn btn-primary">Register</button>
    <p class="text-muted">Already have an account? <a asp-action="Login">Login here</a>.</p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
