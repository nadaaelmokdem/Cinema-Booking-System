@model Movie
@{
    ViewData["Title"] = Model.Title;
}

<div class="movie-details">
    <img src="@(string.IsNullOrEmpty(Model.PosterPath) ? "/images/posters/placeholder.png" : Model.PosterPath)" alt="@Model.Title poster" class="movie-poster-large" />
    <div class="movie-details-body">
        <h1>@Model.Title</h1>
        <p class="text-muted">@Model.Category?.Name &middot; @Model.DurationMinutes min &middot; Released @Model.ReleaseDate.ToString("MMM yyyy")</p>
        <p>@Model.Description</p>
    </div>
</div>

<h2>Showtimes</h2>

@if (!Model.Showtimes.Any())
{
    <p class="text-muted">No upcoming showtimes scheduled for this movie yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Cinema</th>
                <th>Hall</th>
                <th>Date &amp; Time</th>
                <th>Price</th>
                <th>Seats Left</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var showtime in Model.Showtimes)
            {
                <tr>
                    <td data-label="Cinema">@showtime.Hall?.Cinema?.Name</td>
                    <td data-label="Hall">@showtime.Hall?.Name</td>
                    <td data-label="Date & Time">@showtime.StartTime.ToString("ddd, dd MMM yyyy - HH:mm")</td>
                    <td data-label="Price">@showtime.TicketPrice.ToString("C")</td>
                    <td data-label="Seats Left">@showtime.SeatsAvailable</td>
                    <td data-label="">
                        @if (showtime.SeatsAvailable > 0)
                        {
                            <a class="btn btn-primary btn-sm" asp-controller="Bookings" asp-action="Create" asp-route-id="@showtime.Id">Book</a>
                        }
                        else
                        {
                            <span class="badge badge-muted">Sold Out</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
