@model MovieFormViewModel
@{
    ViewData["Title"] = "Edit Movie";
}

<h1>Edit Movie</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="form">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ExistingPosterPath" />

    @if (!string.IsNullOrEmpty(Model.ExistingPosterPath))
    {
        <img src="@Model.ExistingPosterPath" alt="Current poster" class="thumb-large" />
    }

    <div class="form-group">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId"></label>
        <select asp-for="CategoryId" class="form-control">
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Value" selected="@(c.Value == Model.CategoryId.ToString())">@c.Text</option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="DurationMinutes"></label>
        <input asp-for="DurationMinutes" type="number" class="form-control" />
        <span asp-validation-for="DurationMinutes" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="ReleaseDate"></label>
        <input asp-for="ReleaseDate" type="date" class="form-control" value="@Model.ReleaseDate.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="ReleaseDate" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="PosterFile"></label>
        <input asp-for="PosterFile" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control" />
        <span asp-validation-for="PosterFile" class="field-error"></span>
        <small class="text-muted">Leave empty to keep the current poster.</small>
    </div>

    <div class="form-group form-check">
        <label>
            <input asp-for="IsShowing" /> Currently showing
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
