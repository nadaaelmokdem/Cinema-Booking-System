@model List<Cinema>
@{
    ViewData["Title"] = "Cinemas";
}

<h1>Cinemas</h1>
<a class="btn btn-primary" asp-action="Create">+ New Cinema</a>

<table class="table">
    <thead><tr><th>Name</th><th>City</th><th>Address</th><th>Halls</th><th></th></tr></thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td data-label="Name">@c.Name</td>
                <td data-label="City">@c.City</td>
                <td data-label="Address">@c.Address</td>
                <td data-label="Halls">@c.Halls.Count</td>
                <td data-label="">
                    <a class="btn btn-secondary btn-sm" asp-action="Edit" asp-route-id="@c.Id">Edit</a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="inline-form" onsubmit="return confirm('Delete this cinema?');">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
