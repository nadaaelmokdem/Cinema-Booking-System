<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - @ViewData["Title"] - CineBook</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar">
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">🎬 CineBook</a>
            <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">☰</button>
            <div class="nav-links" id="navLinks">
                <a asp-area="Admin" asp-controller="Movies" asp-action="Index">Movies</a>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index">Categories</a>
                <a asp-area="Admin" asp-controller="Cinemas" asp-action="Index">Cinemas</a>
                <a asp-area="Admin" asp-controller="Halls" asp-action="Index">Halls</a>
                <a asp-area="Admin" asp-controller="Showtimes" asp-action="Index">Showtimes</a>
                <a asp-area="Admin" asp-controller="Bookings" asp-action="Index">All Bookings</a>
                <span class="nav-spacer"></span>
                <a asp-area="" asp-controller="Home" asp-action="Index">Public Site</a>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                    <button type="submit" class="link-button">Logout</button>
                </form>
            </div>
        </nav>
    </header>

    <main class="container">
        @if (TempData["SuccessMessage"] is not null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] is not null)
        {
            <div class="alert alert-error">@TempData["ErrorMessage"]</div>
        }

        <h4 class="admin-title">Admin Panel</h4>
        @RenderBody()
    </main>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
