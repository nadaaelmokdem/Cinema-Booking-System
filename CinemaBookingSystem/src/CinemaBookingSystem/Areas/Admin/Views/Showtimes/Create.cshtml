@model Showtime
@{
    ViewData["Title"] = "New Showtime";
    var movies = ViewBag.Movies as List<Movie> ?? new List<Movie>();
    var halls = ViewBag.Halls as List<Hall> ?? new List<Hall>();
}

<h1>New Showtime</h1>

<form asp-action="Create" method="post" class="form form-narrow">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <div class="form-group">
        <label asp-for="MovieId"></label>
        <select asp-for="MovieId" class="form-control">
            <option value="">-- Select Movie --</option>
            @foreach (var m in movies)
            {
                <option value="@m.Id">@m.Title (@m.DurationMinutes min)</option>
            }
        </select>
        <span asp-validation-for="MovieId" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="HallId"></label>
        <select asp-for="HallId" class="form-control">
            <option value="">-- Select Hall --</option>
            @foreach (var h in halls)
            {
                <option value="@h.Id">@h.Cinema?.Name - @h.Name (@h.Capacity seats)</option>
            }
        </select>
        <span asp-validation-for="HallId" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="StartTime"></label>
        <input asp-for="StartTime" type="datetime-local" class="form-control" />
        <span asp-validation-for="StartTime" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="TicketPrice"></label>
        <input asp-for="TicketPrice" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="TicketPrice" class="field-error"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
