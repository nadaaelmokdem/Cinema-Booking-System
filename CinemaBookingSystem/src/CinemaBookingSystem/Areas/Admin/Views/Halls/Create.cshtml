@model Hall
@{
    ViewData["Title"] = "New Hall";
    var cinemas = ViewBag.Cinemas as List<Cinema> ?? new List<Cinema>();
}

<h1>New Hall</h1>

<form asp-action="Create" method="post" class="form form-narrow">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <div class="form-group">
        <label asp-for="CinemaId"></label>
        <select asp-for="CinemaId" class="form-control">
            <option value="">-- Select Cinema --</option>
            @foreach (var c in cinemas)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
        <span asp-validation-for="CinemaId" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Capacity"></label>
        <input asp-for="Capacity" type="number" class="form-control" />
        <span asp-validation-for="Capacity" class="field-error"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
