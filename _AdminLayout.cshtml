@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>

<form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="form form-narrow">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="field-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Password"></label>
        <input asp-for="Password" class="form-control" />
        <span asp-validation-for="Password" class="field-error"></span>
    </div>

    <div class="form-group form-check">
        <label>
            <input asp-for="RememberMe" /> Remember me
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
    <p class="text-muted">New here? <a asp-action="Register">Create an account</a>.</p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
