@model List<Movie>
@{
    ViewData["Title"] = "Movies";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<h1>Movies</h1>

<form method="get" class="filter-bar">
    <input type="text" name="search" value="@ViewBag.Search" placeholder="Search by title..." />
    <select name="categoryId">
        <option value="">All Categories</option>
        @foreach (var c in categories)
        {
            <option value="@c.Id" selected="@(ViewBag.SelectedCategoryId == c.Id)">@c.Name</option>
        }
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
</form>

<div class="movie-grid">
    @foreach (var movie in Model)
    {
        <div class="movie-card">
            <a asp-action="Details" asp-route-id="@movie.Id">
                <img src="@(string.IsNullOrEmpty(movie.PosterPath) ? "/images/posters/placeholder.png" : movie.PosterPath)" alt="@movie.Title poster" class="movie-poster" />
            </a>
            <div class="movie-card-body">
                <h3>@movie.Title</h3>
                <p class="text-muted">@movie.Category?.Name &middot; @movie.DurationMinutes min</p>
                <a class="btn btn-secondary" asp-action="Details" asp-route-id="@movie.Id">View Showtimes</a>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <p class="text-muted">No movies match your search.</p>
}
